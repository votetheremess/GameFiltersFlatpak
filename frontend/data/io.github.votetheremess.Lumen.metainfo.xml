<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.votetheremess.Lumen</id>
  <name>Lumen</name>
  <summary>Live in-game color, contrast, and sharpening filters</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <developer id="io.github.votetheremess">
    <name>votetheremess</name>
  </developer>

  <description>
    <p>
      Lumen is a Linux-native replacement for Nvidia's Freestyle / Game
      Filters overlay. Press a hotkey in any Vulkan game and a live-slider
      sidebar appears with Brightness, Contrast, Shadows, Highlights, Gamma,
      Temperature, Vibrance, Sharpen, Clarity, HDR Toning, Bloom, Vignette,
      and Black &amp; White — applied in real time without editing launch
      options per-game.
    </p>
    <p>
      Filters are stacked like Freestyle: start with nothing active, press
      Add on the cards you want, reorder with Up/Down, remove with Remove.
      Per-game profiles (three slots per game) save your sliders
      automatically. A system-tray daemon keeps the controller alive in the
      background.
    </p>
    <p>
      Runs as an implicit Vulkan layer so every Vulkan application picks it
      up automatically. Targets KDE Plasma on Wayland; Steam Proton games
      load the layer via the Flathub Vulkan-layer extension mechanism.
    </p>
  </description>

  <categories>
    <category>Utility</category>
    <category>Graphics</category>
    <category>Game</category>
  </categories>

